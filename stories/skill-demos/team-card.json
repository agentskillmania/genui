{
  "version": "v0.9",
  "updateComponents": {
    "surfaceId": "team_card",
    "components": [
      {
        "id": "root",
        "component": "Column",
        "children": ["card"]
      },
      {
        "id": "card",
        "component": "Card",
        "children": ["header_row", "stats_row", "divider", "members_list"],
        "title": {"path": "/team/title"},
        "bordered": true,
        "style": {
          "width": "100%",
          "maxWidth": 480
        }
      },
      {
        "id": "header_row",
        "component": "Row",
        "children": ["department_tag", "member_count_text"],
        "justify": "spaceBetween",
        "align": "middle",
        "gutter": 8
      },
      {
        "id": "department_tag",
        "component": "Tag",
        "text": {"path": "/team/department"},
        "color": "geekblue",
        "bordered": true
      },
      {
        "id": "member_count_text",
        "component": "Text",
        "text": {"path": "/team/memberCount"},
        "variant": "caption",
        "color": "#666",
        "style": {
          "whiteSpace": "nowrap"
        }
      },
      {
        "id": "stats_row",
        "component": "Row",
        "children": ["avg_tenure_col", "sprints_col", "satisfaction_col"],
        "gutter": 16,
        "style": {
          "backgroundColor": "rgba(22, 119, 255, 0.04)",
          "borderRadius": 8,
          "padding": "12px 0"
        }
      },
      {
        "id": "avg_tenure_col",
        "component": "Column",
        "children": ["avg_tenure_stat"],
        "flex": 1,
        "style": {
          "textAlign": "center"
        }
      },
      {
        "id": "avg_tenure_stat",
        "component": "Statistic",
        "title": "Avg Tenure",
        "value": {"path": "/team/stats/avgTenure"},
        "suffix": "yrs",
        "precision": 1
      },
      {
        "id": "sprints_col",
        "component": "Column",
        "children": ["sprints_stat"],
        "flex": 1,
        "style": {
          "textAlign": "center"
        }
      },
      {
        "id": "sprints_stat",
        "component": "Statistic",
        "title": "Sprints / Quarter",
        "value": {"path": "/team/stats/sprints"},
        "precision": 0
      },
      {
        "id": "satisfaction_col",
        "component": "Column",
        "children": ["satisfaction_stat"],
        "flex": 1,
        "style": {
          "textAlign": "center"
        }
      },
      {
        "id": "satisfaction_stat",
        "component": "Statistic",
        "title": "Satisfaction",
        "value": {"path": "/team/stats/satisfaction"},
        "suffix": "%",
        "precision": 0
      },
      {
        "id": "divider",
        "component": "Divider",
        "orientation": "left",
        "type": "horizontal",
        "plain": true
      },
      {
        "id": "members_list",
        "component": "Column",
        "children": ["member_1", "member_2", "member_3"],
        "style": {
          "gap": 12
        }
      },
      {
        "id": "member_1",
        "component": "Row",
        "children": ["member_1_avatar", "member_1_info_col", "member_1_role_tag"],
        "align": "middle",
        "gutter": 12,
        "style": {
          "padding": "8px 12px",
          "background": "#fafafa",
          "borderRadius": 8
        }
      },
      {
        "id": "member_1_avatar",
        "component": "Avatar",
        "src": {"path": "/team/members/0/avatar"},
        "alt": {"path": "/team/members/0/name"},
        "size": 40,
        "shape": "circle"
      },
      {
        "id": "member_1_info_col",
        "component": "Column",
        "children": ["member_1_name", "member_1_title"],
        "flex": 1,
        "style": {
          "gap": 2
        }
      },
      {
        "id": "member_1_name",
        "component": "Text",
        "text": {"path": "/team/members/0/name"},
        "variant": "body",
        "strong": true,
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_1_title",
        "component": "Text",
        "text": {"path": "/team/members/0/title"},
        "variant": "caption",
        "color": "#666",
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_1_role_tag",
        "component": "Tag",
        "text": {"path": "/team/members/0/role"},
        "color": "blue"
      },
      {
        "id": "member_2",
        "component": "Row",
        "children": ["member_2_avatar", "member_2_info_col", "member_2_role_tag"],
        "align": "middle",
        "gutter": 12,
        "style": {
          "padding": "8px 12px",
          "background": "#fafafa",
          "borderRadius": 8
        }
      },
      {
        "id": "member_2_avatar",
        "component": "Avatar",
        "src": {"path": "/team/members/1/avatar"},
        "alt": {"path": "/team/members/1/name"},
        "size": 40,
        "shape": "circle"
      },
      {
        "id": "member_2_info_col",
        "component": "Column",
        "children": ["member_2_name", "member_2_title"],
        "flex": 1,
        "style": {
          "gap": 2
        }
      },
      {
        "id": "member_2_name",
        "component": "Text",
        "text": {"path": "/team/members/1/name"},
        "variant": "body",
        "strong": true,
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_2_title",
        "component": "Text",
        "text": {"path": "/team/members/1/title"},
        "variant": "caption",
        "color": "#666",
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_2_role_tag",
        "component": "Tag",
        "text": {"path": "/team/members/1/role"},
        "color": "green"
      },
      {
        "id": "member_3",
        "component": "Row",
        "children": ["member_3_avatar", "member_3_info_col", "member_3_role_tag"],
        "align": "middle",
        "gutter": 12,
        "style": {
          "padding": "8px 12px",
          "background": "#fafafa",
          "borderRadius": 8
        }
      },
      {
        "id": "member_3_avatar",
        "component": "Avatar",
        "src": {"path": "/team/members/2/avatar"},
        "alt": {"path": "/team/members/2/name"},
        "size": 40,
        "shape": "circle"
      },
      {
        "id": "member_3_info_col",
        "component": "Column",
        "children": ["member_3_name", "member_3_title"],
        "flex": 1,
        "style": {
          "gap": 2
        }
      },
      {
        "id": "member_3_name",
        "component": "Text",
        "text": {"path": "/team/members/2/name"},
        "variant": "body",
        "strong": true,
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_3_title",
        "component": "Text",
        "text": {"path": "/team/members/2/title"},
        "variant": "caption",
        "color": "#666",
        "style": {
          "margin": 0
        }
      },
      {
        "id": "member_3_role_tag",
        "component": "Tag",
        "text": {"path": "/team/members/2/role"},
        "color": "orange"
      }
    ]
  }
}
