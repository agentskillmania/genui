        "id": "item1_price",
        "component": "Text",
        "text": { "path": "/order/items/0/price" },
        "variant": "body",
        "strong": true,
        "style": { "margin": 0 }
      },
      {
        "id": "item_row2",
        "component": "Row",
        "children": ["item2_name", "item2_qty", "item2_price"],
