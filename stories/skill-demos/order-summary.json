        "align": "middle",
        "style": { "marginBottom": 8 }
      },
      {
        "id": "item2_name",
        "component": "Text",
        "text": { "path": "/order/items/1/name" },
        "variant": "body",
        "style": { "margin": 0 }
      },
      {
        "id": "item2_qty",
        "component": "Text",
        "text": { "path": "/order/items/1/qty" },
        "variant": "caption",
        "style": { "margin": 0 }
      },
      {
        "id": "item2_price",
        "component": "Text",
        "text": { "path": "/order/items/1/price" },
        "variant": "body",
        "strong": true,
        "style": { "margin": 0 }
