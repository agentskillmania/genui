        "id": "back_btn",
        "component": "Button",
        "text": "Back to Orders",
        "variant": "default"
      },
      {
        "id": "track_btn",
        "component": "Button",
        "text": "Track Package",
        "variant": "primary",
        "action": { "event": { "name": "trackOrder", "context": { "orderId": { "path": "/order/orderId" } } } }
      }
    ]
  }
