      {
        "id": "total_label",
        "component": "Text",
        "text": "Total",
        "variant": "h4",
        "strong": true,
        "style": { "margin": 0 }
      },
      {
        "id": "total_value",
        "component": "Text",
        "text": { "path": "/order/total" },
        "variant": "h4",
        "strong": true,
        "style": { "margin": 0, "color": "#1677ff" }
