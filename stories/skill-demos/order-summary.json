      {
        "id": "status_row",
        "component": "Row",
        "children": ["status_tag", "date_text"],
        "justify": "spaceBetween",
        "align": "middle",
        "style": { "marginTop": 8 }
      },
      {
        "id": "status_tag",
        "component": "Tag",
        "text": { "path": "/order/status" },
        "color": "blue"
      },
      {
        "id": "date_text",
        "component": "Text",
        "text": { "path": "/order/date" },
        "variant": "caption",
        "style": { "margin": 0 }
      },
      {
        "id": "divider3",
        "component": "Divider",
        "style": { "margin": "12px 0" }
