      {
        "id": "divider2",
        "component": "Divider",
        "style": { "margin": "12px 0" }
      },
      {
        "id": "total_row",
        "component": "Row",
        "children": ["total_label", "total_value"],
        "justify": "spaceBetween",
        "align": "middle"
